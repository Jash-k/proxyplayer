# Server environment variables
# Copy to server/.env for local development

PORT=3001
NODE_ENV=development

# M3U playlist source URL
M3U_SOURCE=https://pocket-tv-tamil-5afe35.gitlab.io/jiostar.m3u

# Set to true during development to allow all CORS origins
ALLOW_ALL_ORIGINS=true

# Your deployed server base URL (for HLS manifest URL rewriting)
# Leave empty in development — relative URLs will be used
# SERVER_BASE_URL=https://jiostar-player.onrender.com
